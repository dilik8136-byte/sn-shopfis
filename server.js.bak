function ensureDataFile() {
  if (!fs.existsSync(dataFile)) {
    fs.writeFileSync(dataFile, JSON.stringify(defaultData, null, 2), 'utf8');
  }
}
ensureDataFile();

async function readData() {
  ensureDataFile();
  const raw = await fsp.readFile(dataFile, 'utf8');
  return JSON.parse(raw);
}

async function writeData(data) {
  await fsp.writeFile(dataFile, JSON.stringify(data, null, 2), 'utf8');
}

function normalizeUsername(raw) {
  return String(raw || '').trim().replace(/^@/, '');
}

function normalizeSellerContact(raw) {
  const value = String(raw || '').trim();
  if (!value) return '';
  if (/^https?:\/\/t\.me\//i.test(value)) return value;
  if (/^t\.me\//i.test(value)) return 'https://' + value;
  if (/^@/.test(value)) return 'https://t.me/' + value.slice(1);
  return value;
}

function isAdmin(username) {
  return ADMIN_USERNAMES.includes(normalizeUsername(username));
}

async function isSeller(username) {
  const u = normalizeUsername(username);
  if (!u) return false;
  if (isAdmin(u)) return true;
  const data = await readData();
  return data.sellers.some((seller) => normalizeUsername(seller.username) === u);
}

function slugify(value) {
  const base = String(value || '')
    .trim()
    .toLowerCase()
    .replace(/[а-яё]/gi, (ch) => {
      const map = {
        а:'a',б:'b',в:'v',г:'g',д:'d',е:'e',ё:'e',ж:'zh',з:'z',и:'i',й:'y',к:'k',л:'l',м:'m',н:'n',о:'o',п:'p',р:'r',с:'s',т:'t',у:'u',ф:'f',х:'h',ц:'c',ч:'ch',ш:'sh',щ:'sch',ъ:'',ы:'y',ь:'',э:'e',ю:'yu',я:'ya'
      };
      return map[ch.toLowerCase()] || '';
    })
    .replace(/[^a-z0-9]+/g, '-')
    .replace(/^-+|-+$/g, '');
  return base || crypto.randomUUID().slice(0, 8);
}

function safeBadges(list) {
  return (Array.isArray(list) ? list : []).map((v) => String(v).trim()).filter(Boolean).slice(0, 3);
}

function cleanImages(files, existingGallery = []) {
  const uploaded = (files || []).map((file) => `/uploads/${file.filename}`);
  return [...existingGallery.filter(Boolean), ...uploaded].slice(0, 10);
}

const upload = multer({
  storage: multer.diskStorage({
    destination: (_req, _file, cb) => cb(null, uploadsDir),
    filename: (_req, file, cb) => {
      const ext = path.extname(file.originalname || '').toLowerCase();
      cb(null, `${Date.now()}-${crypto.randomUUID().slice(0, 8)}${ext || '.jpg'}`);
    }
  }),
  limits: { fileSize: 8 * 1024 * 1024, files: 8 }
});

app.get('/api/stores', async (_req, res) => {
  const data = await readData();
  const stores = Object.values(storeMeta).map((store) => ({
    ...store,
    categories: data.categories.filter((category) => category.store === store.key),
    productsCount: data.products.filter((product) => product.store === store.key).length
  }));
  res.json({ stores });
});

app.get('/api/store/:key', async (req, res) => {
  const store = storeMeta[req.params.key];
  if (!store) return res.status(404).json({ error: 'Магазин не найден' });
  const data = await readData();
  const categories = data.categories.filter((category) => category.store === store.key);
  const products = data.products
    .filter((product) => product.store === store.key)
    .sort((a, b) => b.id - a.id);
  res.json({ store, categories, products });
});

app.get('/api/store/:store/product/:slug', async (req, res) => {
  const { store, slug } = req.params;
  const data = await readData();
  const product = data.products.find((item) => item.store === store && item.slug === slug);
  if (!product) return res.status(404).json({ error: 'Товар не найден' });
  res.json(product);
});

app.get('/api/roles/:username', async (req, res) => {
  const username = normalizeUsername(req.params.username);
  res.json({
    isAdmin: isAdmin(username),
    isSeller: await isSeller(username)
  });
});

app.get('/api/seller/:username', async (req, res) => {
  const username = normalizeUsername(req.params.username);
  const store = String(req.query.store || '').trim();
  const data = await readData();
  const products = data.products
    .filter((product) => normalizeUsername(product.sellerUsername) === username && (!store || product.store === store))
    .sort((a, b) => b.id - a.id);
  const sellerStores = [...new Set(products.map((product) => product.store))].map((key) => storeMeta[key]).filter(Boolean);
  res.json({
    seller: username,
    displayName: data.sellers.find((seller) => normalizeUsername(seller.username) === username)?.displayName || username,
    products,
    stores: sellerStores
  });
});

app.post('/api/categories', async (req, res) => {
  const { store, name, slug, by } = req.body || {};
  if (!storeMeta[store]) return res.status(400).json({ error: 'Неверный магазин' });
  if (!(await isSeller(by))) return res.status(403).json({ error: 'Нет прав продавца' });
  const data = await readData();
  const finalSlug = slugify(slug || name);
  if (data.categories.some((item) => item.store === store && item.slug === finalSlug)) {
    return res.status(400).json({ error: 'Такая категория уже есть' });
  }
  data.lastIds.category += 1;
  const category = { id: data.lastIds.category, store, name: String(name || '').trim(), slug: finalSlug, createdBy: normalizeUsername(by) };
  data.categories.push(category);
  await writeData(data);
  res.json({ ok: true, category });
});

app.post('/api/products', upload.array('images', 8), async (req, res) => {
  const body = req.body || {};
  const username = normalizeUsername(body.by);
  if (!(await isSeller(username))) return res.status(403).json({ error: 'Нет прав продавца' });
  const store = String(body.store || '').trim();
  if (!storeMeta[store]) return res.status(400).json({ error: 'Неверный магазин' });

  const data = await readData();
  const categorySlug = String(body.category_slug || '').trim();
  if (!data.categories.some((category) => category.store === store && category.slug === categorySlug)) {
    return res.status(400).json({ error: 'Категория не найдена' });
  }

  const parsedExistingGallery = body.existingGallery ? JSON.parse(body.existingGallery) : [];
  const gallery = cleanImages(req.files, Array.isArray(parsedExistingGallery) ? parsedExistingGallery : []);
  const mainImage = gallery[0] || parsedExistingGallery[0] || '';
  const finalSlug = slugify(body.slug || body.title);
  if (data.products.some((product) => product.store === store && product.slug === finalSlug)) {
    return res.status(400).json({ error: 'Такой slug уже занят' });
  }

  data.lastIds.product += 1;
  const product = {
    id: data.lastIds.product,
    store,
    categorySlug,
    title: String(body.title || '').trim(),
    slug: finalSlug,
    shortDescription: String(body.short_description || '').trim(),
    fullDescription: String(body.full_description || '').trim(),
    price: Number(body.price || 0),
    sellerUsername: username,
    sellerContact: normalizeSellerContact(body.seller_contact),
    sellerLabel: String(body.seller_label || '').trim() || String(body.seller_contact || '').trim() || `@${username}`,
    mainImage,
    gallery,
    badges: safeBadges(JSON.parse(body.badges || '[]')),
    type: String(body.type || 'physical').trim(),
    createdAt: new Date().toISOString()
  };

  data.products.push(product);
  if (!data.sellers.some((seller) => normalizeUsername(seller.username) === username)) {
    data.sellers.push({ username, displayName: username, createdAt: new Date().toISOString() });
  }
  await writeData(data);
  res.json({ ok: true, product, slug: product.slug });
});

app.put('/api/products/:id', upload.array('images', 8), async (req, res) => {
  const id = Number(req.params.id);
  const body = req.body || {};
  const username = normalizeUsername(body.by);
  const data = await readData();
  const product = data.products.find((item) => item.id === id);
  if (!product) return res.status(404).json({ error: 'Товар не найден' });
  const allowed = isAdmin(username) || normalizeUsername(product.sellerUsername) === username;
  if (!allowed) return res.status(403).json({ error: 'Нет доступа' });

  const parsedExistingGallery = body.existingGallery ? JSON.parse(body.existingGallery) : product.gallery || [];
  const filteredExisting = Array.isArray(parsedExistingGallery) ? parsedExistingGallery.filter(Boolean) : [];
  const gallery = cleanImages(req.files, filteredExisting);
  const nextStore = String(body.store || product.store).trim();
  if (!storeMeta[nextStore]) return res.status(400).json({ error: 'Неверный магазин' });
  const categorySlug = String(body.category_slug || product.categorySlug).trim();
  if (!data.categories.some((category) => category.store === nextStore && category.slug === categorySlug)) {
    return res.status(400).json({ error: 'Категория не найдена' });
  }
  const nextSlug = slugify(body.slug || product.slug || body.title || product.title);
  if (data.products.some((item) => item.id !== id && item.store === nextStore && item.slug === nextSlug)) {
    return res.status(400).json({ error: 'Такой slug уже занят' });
  }

  Object.assign(product, {
    store: nextStore,
    categorySlug,
    title: String(body.title || product.title).trim(),
    slug: nextSlug,
    shortDescription: String(body.short_description ?? product.shortDescription).trim(),
    fullDescription: String(body.full_description ?? product.fullDescription).trim(),
    price: Number(body.price ?? product.price),
    sellerContact: normalizeSellerContact(body.seller_contact || product.sellerContact),
    sellerLabel: String(body.seller_label || product.sellerLabel || body.seller_contact || product.sellerContact).trim(),
    gallery,
    mainImage: gallery[0] || '',
    badges: safeBadges(JSON.parse(body.badges || JSON.stringify(product.badges || []))),
    type: String(body.type || product.type || 'physical').trim()
  });

  await writeData(data);
  res.json({ ok: true, product });
});

app.delete('/api/products/:id', async (req, res) => {
  const id = Number(req.params.id);
  const username = normalizeUsername(req.query.by);
  const data = await readData();
  const product = data.products.find((item) => item.id === id);
  if (!product) return res.status(404).json({ error: 'Товар не найден' });
  const allowed = isAdmin(username) || normalizeUsername(product.sellerUsername) === username;
  if (!allowed) return res.status(403).json({ error: 'Нет доступа' });
  data.products = data.products.filter((item) => item.id !== id);
  await writeData(data);
  res.json({ ok: true });
});

app.get('*', (_req, res) => {
  res.sendFile(path.join(__dirname, 'public', 'index.html'));
});

app.listen(PORT, () => {
  console.log(`SN Shop running on ${BASE_URL}`);
});

if (BOT_TOKEN) {
  const bot = new Telegraf(BOT_TOKEN);

  bot.start(async (ctx) => {
    const username = normalizeUsername(ctx.from?.username);
    const seller = await isSeller(username);
    const rows = [
      [Markup.button.webApp('👕 Магазин одежды · TripShop', `${BASE_URL}/?store=tripshop`)],
      [Markup.button.webApp('🧩 Магазин плагинов · LimbPL', `${BASE_URL}/?store=limbpl`)],
      [Markup.button.webApp('🧸 Магазин игрушек · TripToys', `${BASE_URL}/?store=triptoys`)],
      [Markup.button.webApp('📦 Заказы с Китая · TripChinaShop', `${BASE_URL}/?store=tripchinashop`)]
    ];
    if (seller && username) {
      rows.push([Markup.button.webApp('🧑‍💼 Мой кабинет продавца', `${BASE_URL}/?seller=${username}&dashboard=1`)]);
    }
    await ctx.reply('Добро пожаловать в SN Shop. Выбери магазин ниже:', Markup.inlineKeyboard(rows));
  });

  bot.command('seller_add', async (ctx) => {
    const admin = normalizeUsername(ctx.from?.username);
    if (!isAdmin(admin)) return ctx.reply('Нет доступа.');
    const arg = normalizeUsername(ctx.message.text.split(' ')[1]);
    if (!arg) return ctx.reply('Используй: /seller_add @username');
    const data = await readData();
    if (!data.sellers.some((seller) => normalizeUsername(seller.username) === arg)) {
      data.sellers.push({ username: arg, displayName: arg, createdAt: new Date().toISOString() });
      await writeData(data);
    }
    await ctx.reply(`Продавец @${arg} добавлен.`);
  });

  bot.command('seller_remove', async (ctx) => {
    const admin = normalizeUsername(ctx.from?.username);
    if (!isAdmin(admin)) return ctx.reply('Нет доступа.');
    const arg = normalizeUsername(ctx.message.text.split(' ')[1]);
    if (!arg) return ctx.reply('Используй: /seller_remove @username');
    const data = await readData();
    data.sellers = data.sellers.filter((seller) => normalizeUsername(seller.username) !== arg);
    await writeData(data);
    await ctx.reply(`Продавец @${arg} удалён.`);
  });

  bot.catch((err) => console.error('Telegram bot error', err));
  bot.launch().then(() => console.log('Telegram bot launched')).catch((err) => console.error('Telegram launch error', err));

  process.once('SIGINT', () => bot.stop('SIGINT'));
  process.once('SIGTERM', () => bot.stop('SIGTERM'));
}
